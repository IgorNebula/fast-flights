<?xml version="1.0" encoding="utf-8" ?>
<!-- Using CommunityToolkit -->
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:toolkit="http://schemas.microsoft.com/dotnet/2022/maui/toolkit"
             x:Class="fast_flights.Presentation.Views.FlightsPage"
             BackgroundColor="#2A2F44">
       <ScrollView>
              <VerticalStackLayout Spacing="8"
                                   Padding="16">

                     <!-- From Location -->
                     <VerticalStackLayout Spacing="4">
                            <Label Text="From"
                                   TextColor="White"
                                   FontSize="12"
                                   Margin="8,0,0,0"/>
                            <Border BackgroundColor="#3A3F54"
                                    Stroke="Transparent"
                                    StrokeShape="RoundRectangle 10"
                                    Padding="16,8">
                                   <Grid ColumnDefinitions="Auto, *">
                                          <Image Grid.Column="0"
                                                 Source="departure.png"
                                                 WidthRequest="24"
                                                 HeightRequest="24"
                                                 Margin="0,0,15,0"
                                                 VerticalOptions="Center"/>
                                          <Picker Grid.Column="1"
                                                  TextColor="White"
                                                  FontSize="16"
                                                  VerticalOptions="Center"/>
                                   </Grid>
                            </Border>
                     </VerticalStackLayout>

                     <!-- Swap Button -->
                     <Button Text="⇅"
                             TextColor="#997AED"
                             BackgroundColor="#F2F5F8"
                             CornerRadius="17"
                             WidthRequest="34"
                             HeightRequest="34"
                             HorizontalOptions="Center"
                             Margin="0,5"/>

                     <!-- To Location -->
                     <VerticalStackLayout Spacing="8">
                            <Label Text="To"
                                   TextColor="White"
                                   FontSize="12"
                                   Margin="8,0,0,0"/>
                            <Border BackgroundColor="#3A3F54"
                                    Stroke="Transparent"
                                    StrokeShape="RoundRectangle 10"
                                    Padding="16,8">
                                   <Grid ColumnDefinitions="Auto, *">
                                          <Image Grid.Column="0"
                                                 Source="arrival.png"
                                                 WidthRequest="24"
                                                 HeightRequest="24"
                                                 Margin="0,0,15,0"
                                                 VerticalOptions="Center"/>
                                          <Picker Grid.Column="1"
                                                  TextColor="White"
                                                  FontSize="16"
                                                  VerticalOptions="Center"/>
                                   </Grid>
                            </Border>
                     </VerticalStackLayout>

                     <!-- Departure Date -->
                     <VerticalStackLayout Spacing="8">
                            <Label Text="Departure Date"
                                   TextColor="White"
                                   FontSize="12"
                                   Margin="8,0,0,0"/>
                            <Border BackgroundColor="#3A3F54"
                                    Stroke="Transparent"
                                    StrokeShape="RoundRectangle 10"
                                    Padding="16,8">
                                   <Grid ColumnDefinitions="Auto, Auto, *">
                                          <Image Grid.Column="0"
                                                 Source="calendar_with_dates.png"
                                                 WidthRequest="24"
                                                 HeightRequest="24"
                                                 Margin="0,0,15,0"
                                                 VerticalOptions="Center"/>
                                          <DatePicker Grid.Column="1"
                                                      TextColor="White"
                                                      FontSize="16"
                                                      VerticalOptions="Center"/>
                                          <TimePicker Grid.Column="2"
                                                      TextColor="White"
                                                      FontSize="16"
                                                      VerticalOptions="Center"/>
                                   </Grid>
                            </Border>
                     </VerticalStackLayout>

                     <!-- Return Date -->
                     <VerticalStackLayout Spacing="8">
                            <Label Text="Return Date"
                                   TextColor="White"
                                   FontSize="12"
                                   Margin="8,0,0,0"/>
                            <Border BackgroundColor="#3A3F54"
                                    Stroke="Transparent"
                                    StrokeShape="RoundRectangle 10"
                                    Padding="16,8">
                                   <Grid ColumnDefinitions="Auto, Auto, *">
                                          <Image Grid.Column="0"
                                                 Source="calendar_with_dates.png"
                                                 WidthRequest="24"
                                                 HeightRequest="24"
                                                 Margin="0,0,15,0"
                                                 VerticalOptions="Center"/>
                                          <DatePicker Grid.Column="1"
                                                      TextColor="White"
                                                      FontSize="16"
                                                      VerticalOptions="Center"/>
                                          <TimePicker Grid.Column="2"
                                                      TextColor="White"
                                                      FontSize="16"
                                                      VerticalOptions="Center"/>
                                   </Grid>
                            </Border>
                     </VerticalStackLayout>

                     <!-- Passengers -->
                     <VerticalStackLayout Spacing="8">
                            <Label Text="Passengers"
                                   TextColor="White"
                                   FontSize="12"
                                   Margin="8,0,0,0"/>
                            <Border BackgroundColor="#3A3F54"
                                    Stroke="Transparent"
                                    StrokeShape="RoundRectangle 10"
                                    Padding="16,8">
                                   <Grid ColumnDefinitions="Auto, *">
                                          <Image Grid.Column="0"
                                                 Source="person_solid.png"
                                                 WidthRequest="24"
                                                 HeightRequest="24"
                                                 Margin="0,0,15,0"
                                                 VerticalOptions="Center"/>
                                          <Picker Grid.Column="1"
                                                  TextColor="White"
                                                  FontSize="16"
                                                  VerticalOptions="Center"/>
                                   </Grid>
                            </Border>
                     </VerticalStackLayout>

                     <!-- Kids -->
                     <VerticalStackLayout Spacing="8">
                            <Label Text="Kids"
                                   TextColor="White"
                                   FontSize="12"
                                   Margin="8,0,0,0"/>
                            <Border BackgroundColor="#3A3F54"
                                    Stroke="Transparent"
                                    StrokeShape="RoundRectangle 10"
                                    Padding="16,8">
                                   <Grid ColumnDefinitions="Auto, *">
                                          <Image Grid.Column="0"
                                                 Source="fa6_solid_children.png"
                                                 WidthRequest="24"
                                                 HeightRequest="24"
                                                 Margin="0,0,15,0"
                                                 VerticalOptions="Center"/>
                                          <Picker Grid.Column="1"
                                                  TextColor="White"
                                                  FontSize="16"
                                                  VerticalOptions="Center"/>
                                   </Grid>
                            </Border>
                     </VerticalStackLayout>

                     <!-- Seat Class -->
                     <VerticalStackLayout Spacing="8">
                            <Label Text="Seat Class"
                                   TextColor="White"
                                   FontSize="12"
                                   Margin="8,0,0,0"/>
                            <Border BackgroundColor="#3A3F54"
                                    Stroke="Transparent"
                                    StrokeShape="RoundRectangle 10"
                                    Padding="16,8">
                                   <Grid ColumnDefinitions="Auto, *">
                                          <Image Grid.Column="0"
                                                 Source="ph_seat.png"
                                                 WidthRequest="24"
                                                 HeightRequest="24"
                                                 Margin="0,0,15,0"
                                                 VerticalOptions="Center"/>
                                          <Picker Grid.Column="1"
                                                  TextColor="White"
                                                  FontSize="16"
                                                  VerticalOptions="Center"/>
                                   </Grid>
                            </Border>
                     </VerticalStackLayout>

                     <!-- Search Button -->
                     <Button Text="Search"
                             TextColor="White"
                             BackgroundColor="#997AED"
                             CornerRadius="10"
                             FontSize="18"
                             FontAttributes="Bold"
                             Margin="0,20,0,0"
                             HeightRequest="50"/>

              </VerticalStackLayout>
       </ScrollView>
</ContentPage>