<?xml version="1.0" encoding="UTF-8" ?>
<Shell
    x:Class="fast_flights.AppShell"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:local="clr-namespace:fast_flights"
    Title="fast_flights">

    <Shell.FlyoutHeader>
		<Grid HeightRequest="64" BackgroundColor="#2A2F44"/>
    </Shell.FlyoutHeader>
    <ShellContent 
        Title="Flights"
        ContentTemplate="{DataTemplate local:Presentation.Views.FlightsPage}"
        Route="FlightsPage"/>

</Shell>
