<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="FastFlights.Views.FlightsPage"
             BackgroundColor="#2A2F44">

    <Grid RowDefinitions="Auto, Auto, Auto, Auto, Auto, Auto, Auto, Auto, Auto, Auto, *"
          Padding="20,40,20,20">

        <!-- Trip Type Selection -->
        <FlexLayout Grid.Row="0" 
                   JustifyContent="SpaceBetween" 
                   Margin="0,0,0,20">
            <Frame BackgroundColor="Transparent" 
                   BorderColor="#997AED" 
                   CornerRadius="20" 
                   Padding="15,8" 
                   HasShadow="False">
                <Label Text="One-way" 
                       TextColor="White" 
                       FontSize="14"/>
            </Frame>
            <Frame BackgroundColor="Transparent" 
                   BorderColor="Transparent" 
                   CornerRadius="20" 
                   Padding="15,8" 
                   HasShadow="False">
                <Label Text="Round Trip" 
                       TextColor="White" 
                       FontSize="14"/>
            </Frame>
            <Frame BackgroundColor="Transparent" 
                   BorderColor="Transparent" 
                   CornerRadius="20" 
                   Padding="15,8" 
                   HasShadow="False">
                <Label Text="Multi-city" 
                       TextColor="White" 
                       FontSize="14"/>
            </Frame>
        </FlexLayout>

        <!-- From Location -->
        <Grid Grid.Row="1" Margin="0,10">
            <Label Text="From" 
                   TextColor="White" 
                   FontSize="12" 
                   Margin="0,0,0,5"/>
            <Frame BackgroundColor="#3A3F54" 
                   BorderColor="Transparent" 
                   CornerRadius="10" 
                   Padding="15,10" 
                   HasShadow="False">
                <Grid ColumnDefinitions="Auto, *">
                    <Label Grid.Column="0" 
                           Text="✈" 
                           TextColor="#997AED" 
                           FontSize="24" 
                           Margin="0,0,15,0"/>
                    <Label Grid.Column="1" 
                           Text="Jakarta, Indonesia" 
                           TextColor="White" 
                           FontSize="16" 
                           VerticalOptions="Center"/>
                </Grid>
            </Frame>
        </Grid>

        <!-- Swap Button -->
        <Button Grid.Row="2" 
                Text="⇅" 
                TextColor="#997AED" 
                BackgroundColor="#F2F5F8" 
                CornerRadius="17" 
                WidthRequest="34" 
                HeightRequest="34" 
                HorizontalOptions="Center" 
                Margin="0,5"/>

        <!-- To Location -->
        <Grid Grid.Row="3" Margin="0,10">
            <Label Text="To" 
                   TextColor="White" 
                   FontSize="12" 
                   Margin="0,0,0,5"/>
            <Frame BackgroundColor="#3A3F54" 
                   BorderColor="Transparent" 
                   CornerRadius="10" 
                   Padding="15,10" 
                   HasShadow="False">
                <Grid ColumnDefinitions="Auto, *">
                    <Label Grid.Column="0" 
                           Text="🛬" 
                           TextColor="#997AED" 
                           FontSize="24" 
                           Margin="0,0,15,0"/>
                    <Label Grid.Column="1" 
                           Text="Tokyo, Japan" 
                           TextColor="White" 
                           FontSize="16" 
                           VerticalOptions="Center"/>
                </Grid>
            </Frame>
        </Grid>

        <!-- Departure Date -->
        <Grid Grid.Row="4" Margin="0,10">
            <Label Text="Departure Date" 
                   TextColor="White" 
                   FontSize="12" 
                   Margin="0,0,0,5"/>
            <Frame BackgroundColor="#3A3F54" 
                   BorderColor="Transparent" 
                   CornerRadius="10" 
                   Padding="15,10" 
                   HasShadow="False">
                <Grid ColumnDefinitions="Auto, *">
                    <Label Grid.Column="0" 
                           Text="📅" 
                           TextColor="#997AED" 
                           FontSize="24" 
                           Margin="0,0,15,0"/>
                    <Label Grid.Column="1" 
                           Text="Sat, 20 Mar 2026" 
                           TextColor="White" 
                           FontSize="16" 
                           VerticalOptions="Center"/>
                </Grid>
            </Frame>
        </Grid>

        <!-- Return Date -->
        <Grid Grid.Row="5" Margin="0,10">
            <Label Text="Return Date" 
                   TextColor="White" 
                   FontSize="12" 
                   Margin="0,0,0,5"/>
            <Frame BackgroundColor="#3A3F54" 
                   BorderColor="Transparent" 
                   CornerRadius="10" 
                   Padding="15,10" 
                   HasShadow="False">
                <Grid ColumnDefinitions="Auto, *">
                    <Label Grid.Column="0" 
                           Text="📅" 
                           TextColor="#997AED" 
                           FontSize="24" 
                           Margin="0,0,15,0"/>
                    <Label Grid.Column="1" 
                           Text="Wed, 02 Apr 2026" 
                           TextColor="White" 
                           FontSize="16" 
                           VerticalOptions="Center"/>
                </Grid>
            </Frame>
        </Grid>

        <!-- Passengers -->
        <Grid Grid.Row="6" Margin="0,10">
            <Label Text="Passengers" 
                   TextColor="White" 
                   FontSize="12" 
                   Margin="0,0,0,5"/>
            <Frame BackgroundColor="#3A3F54" 
                   BorderColor="Transparent" 
                   CornerRadius="10" 
                   Padding="15,10" 
                   HasShadow="False">
                <Grid ColumnDefinitions="Auto, *">
                    <Label Grid.Column="0" 
                           Text="👤" 
                           TextColor="#997AED" 
                           FontSize="24" 
                           Margin="0,0,15,0"/>
                    <Label Grid.Column="1" 
                           Text="1 adult" 
                           TextColor="White" 
                           FontSize="16" 
                           VerticalOptions="Center"/>
                </Grid>
            </Frame>
        </Grid>

        <!-- Kids -->
        <Grid Grid.Row="7" Margin="0,10">
            <Label Text="Kids" 
                   TextColor="White" 
                   FontSize="12" 
                   Margin="0,0,0,5"/>
            <Frame BackgroundColor="#3A3F54" 
                   BorderColor="Transparent" 
                   CornerRadius="10" 
                   Padding="15,10" 
                   HasShadow="False">
                <Grid ColumnDefinitions="Auto, *">
                    <Label Grid.Column="0" 
                           Text="👶" 
                           TextColor="#997AED" 
                           FontSize="24" 
                           Margin="0,0,15,0"/>
                    <Label Grid.Column="1" 
                           Text="1 kid (3 years old)" 
                           TextColor="White" 
                           FontSize="16" 
                           VerticalOptions="Center"/>
                </Grid>
            </Frame>
        </Grid>

        <!-- Seat Class -->
        <Grid Grid.Row="8" Margin="0,10">
            <Label Text="Seat Class" 
                   TextColor="White" 
                   FontSize="12" 
                   Margin="0,0,0,5"/>
            <Frame BackgroundColor="#3A3F54" 
                   BorderColor="Transparent" 
                   CornerRadius="10" 
                   Padding="15,10" 
                   HasShadow="False">
                <Grid ColumnDefinitions="Auto, *">
                    <Label Grid.Column="0" 
                           Text="💺" 
                           TextColor="#997AED" 
                           FontSize="24" 
                           Margin="0,0,15,0"/>
                    <Label Grid.Column="1" 
                           Text="Economy" 
                           TextColor="White" 
                           FontSize="16" 
                           VerticalOptions="Center"/>
                </Grid>
            </Frame>
        </Grid>

        <!-- Search Button -->
        <Button Grid.Row="9" 
                Text="Search" 
                TextColor="White" 
                BackgroundColor="#997AED" 
                CornerRadius="10" 
                FontSize="18" 
                FontAttributes="Bold" 
                Margin="0,20,0,0"
                HeightRequest="50"/>

    </Grid>
</ContentPage>
